# Kopyala: cp .env.example .env.local (yerel geliştirme)
# Render: Dashboard → Environment → aşağıdaki değişkenleri tek tek ekle

# ─── Supabase (zorunlu) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin panel (production'da zorunlu) ────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Resend (sipariş e-postası — isteğe bağlı) ──────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_ORDER_EMAIL=
EMAIL_REPLY_TO=

# ─── Render / production (isteğe bağlı) ─────────────────────────────────────
# Supabase → Authentication → URL Configuration → Site URL ve Redirect URLs
# NEXT_PUBLIC_SITE_URL=https://your-app.onrender.com
