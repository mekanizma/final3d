# Kopyala: cp .env.example .env.local (yerel geliştirme)
# Render: Dashboard → Environment → aşağıdaki değişkenleri tek tek ekle

# ─── Supabase (zorunlu) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin panel (production'da zorunlu) ────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Resend (sipariş + teklif formları e-postası) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
# Teklif formları (e-posta ile gönder) ve sipariş kopyası bu adrese gider
ADMIN_ORDER_EMAIL=
EMAIL_REPLY_TO=

# ─── WhatsApp (form talepleri + yüzen buton) ────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=905338398293

# ─── Site URL (SEO: sitemap, canonical, OpenGraph) ───────────────────────────
NEXT_PUBLIC_SITE_URL=https://final3d.tr

# ─── Render / production (isteğe bağlı) ─────────────────────────────────────
# Supabase → Authentication → URL Configuration → Site URL ve Redirect URLs
